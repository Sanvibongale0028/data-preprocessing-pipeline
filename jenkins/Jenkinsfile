pipeline {
    agent any

    parameters {
        string(name: 'FILE_NAME', defaultValue: '', description: 'Dataset file name')
    }

    stages {

        stage('Start Pipeline') {
            steps {
                script {
                    if (!params.FILE_NAME) {
                        error "FILE_NAME parameter is required"
                    }
                }
                echo "Pipeline started successfully"
                echo "Dataset received: ${params.FILE_NAME}"
            }
        }

        stage('Prepare Dataset Folder') {
            steps {
                sh '''
                echo "Creating datasets directory in Jenkins workspace"
                mkdir -p datasets
                '''
            }
        }

        stage('Copy Dataset to Workspace') {
            steps {
                sh '''
                echo "Checking if uploaded file exists"

                if [ ! -f "/home/sanvi/Main/TY_Mini_Project/Final_MP/backend/uploads/${FILE_NAME}" ]; then
                    echo "Dataset not found!"
                    exit 1
                fi

                echo "Copying uploaded dataset into Jenkins workspace"

                cp /home/sanvi/Main/TY_Mini_Project/Final_MP/backend/uploads/${FILE_NAME} datasets/

                echo "Checking datasets folder:"
                ls -l datasets
                '''
            }
        }

        stage('Setup Python Environment') {
            steps {
                sh '''
                echo "Setting up Python environment"

                if [ ! -d "venv" ]; then
                    echo "Creating virtual environment"
                    python3 -m venv venv
                fi

                echo "Activating virtual environment"
                . venv/bin/activate

                echo "Upgrading pip"
                pip install --upgrade pip

                echo "Installing project dependencies"
                pip install -r preprocessing/requirements.txt
                '''
            }
        }

        stage('Run Preprocessing Pipeline') {
            steps {
                sh '''
                echo "Running preprocessing pipeline"

                . venv/bin/activate

                echo "Workspace location:"
                pwd

                echo "Files available before preprocessing:"
                ls -l datasets

                python preprocessing/main_pipeline.py datasets/${FILE_NAME}
                '''
            }
        }

        stage('Save Processed File') {
            steps {
                sh '''
                echo "Moving processed dataset back to backend"
                mkdir -p /home/sanvi/Main/TY_Mini_Project/Final_MP/backend/processed

                echo "Deleting old processed file"
                rm -f /home/sanvi/Main/TY_Mini_Project/Final_MP/backend/processed/*

                echo "Extracting file extension"
                EXT="${FILE_NAME##*.}"

                echo "Saving processed file with same extension"

                cp datasets/processed_output.${EXT} /home/sanvi/Main/TY_Mini_Project/Final_MP/backend/processed/processed_output.${EXT}

                echo "Processed file successfully copied"
                '''
            }
        }

        stage('Pipeline Completed') {
            steps {
                echo "Preprocessing pipeline executed successfully"
            }
        }
    }

    post {
        always {
            sh '''
            echo "Cleaning datasets folder to prevent storage buildup"
            rm -rf datasets/*

            echo "Deleting uploaded file from backend/uploads"
            rm -f /home/sanvi/Main/TY_Mini_Project/Final_MP/backend/uploads/${FILE_NAME}

            echo "Cleanup completed"
            '''
        }
    }
}